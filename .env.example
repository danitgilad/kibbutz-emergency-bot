# ============================================
# KIBBUTZ EMERGENCY BOT - Configuration
# ============================================
# Copy this file to .env and fill in your values
# ============================================

# --- Twilio ---
# Get these from https://console.twilio.com
#
# Option 1: Default (flat) credentials — used when TWILIO_PROFILE is not set
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
#
# Option 2: Named profiles — switch accounts by changing one env var
# Set TWILIO_PROFILE to the profile name (e.g. "sandbox" or "production")
# Then define credentials with the pattern: TWILIO_{PROFILE}_ACCOUNT_SID, etc.
#
# TWILIO_PROFILE=sandbox
#
# TWILIO_SANDBOX_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_SANDBOX_AUTH_TOKEN=your_sandbox_token
# TWILIO_SANDBOX_WHATSAPP_NUMBER=whatsapp:+14155238886
#
# TWILIO_PRODUCTION_ACCOUNT_SID=ACyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy
# TWILIO_PRODUCTION_AUTH_TOKEN=your_production_token
# TWILIO_PRODUCTION_WHATSAPP_NUMBER=whatsapp:+972...

# --- Google Sheets ---
# The ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_IS_THE_ID/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Path to your Google service account credentials JSON file
# Download from Google Cloud Console > Service Accounts > Keys
GOOGLE_CREDENTIALS_PATH=./credentials.json

# OR paste the entire service-account JSON as a string (for Render / cloud deploys)
# If set, GOOGLE_CREDENTIALS_PATH is ignored.
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...",...}

# --- App Settings ---
# The coordinator's WhatsApp number (receives approval requests)
COORDINATOR_PHONE=whatsapp:+972501234567

# Port for the web server (Twilio sends webhooks here)
PORT=3000

# Your public URL (needed for Twilio webhooks)
# When using Railway/Render, this is your deployed URL
# For local testing, use ngrok: https://ngrok.com
BASE_URL=https://your-app-name.up.railway.app

# Timezone for roster timestamps (default: Asia/Jerusalem)
TIMEZONE=Asia/Jerusalem

# API key to protect /roster and /personnel admin endpoints
# Generate a random string, e.g.: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADMIN_API_KEY=your_random_api_key_here

# --- Demo Mode ---
# Set to "true" to skip Twilio entirely (messages logged to console)
# Useful for testing without a Twilio account
# DEMO_MODE=true
