# ============================================
# KIBBUTZ EMERGENCY BOT - Configuration
# ============================================
# Copy this file to .env and fill in your values
# ============================================

# --- Twilio ---
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# --- Google Sheets ---
# The ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_IS_THE_ID/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Path to your Google service account credentials JSON file
# Download from Google Cloud Console > Service Accounts > Keys
GOOGLE_CREDENTIALS_PATH=./credentials.json

# --- App Settings ---
# The coordinator's WhatsApp number (receives approval requests)
COORDINATOR_PHONE=whatsapp:+972501234567

# Port for the web server (Twilio sends webhooks here)
PORT=3000

# Your public URL (needed for Twilio webhooks)
# When using Railway/Render, this is your deployed URL
# For local testing, use ngrok: https://ngrok.com
BASE_URL=https://your-app-name.up.railway.app

# Timezone for roster timestamps (default: Asia/Jerusalem)
TIMEZONE=Asia/Jerusalem

# API key to protect /roster and /personnel admin endpoints
# Generate a random string, e.g.: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADMIN_API_KEY=your_random_api_key_here
